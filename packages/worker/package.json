{
    "name": "worker",
    "version": "1.0.0",
    "description": "ATS SaaS Background Worker",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "start": "node dist/index.js",
        "lint": "eslint .",
        "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1037.0",
        "@google/generative-ai": "^0.24.1",
        "@repo/shared": "*",
        "bullmq": "^5.7.8",
        "dotenv": "^16.4.5",
        "ioredis": "^5.9.3",
        "mongoose": "^8.3.1",
        "pdf-parse": "^1.1.1",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/pdf-parse": "^1.1.4",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.4.5"
    }
}